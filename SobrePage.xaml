<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.SobrePage"
             Title="Sobre">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Ícone do app -->
            <Label Text="🏨"
                   FontSize="64"
                   HorizontalOptions="Center" />

            <!-- Nome do app -->
            <Label Text="App Hotel"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#1A73E8" />

            <Label Text="Versão 1.0"
                   FontSize="13"
                   HorizontalOptions="Center"
                   TextColor="#888" />

            <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,4,0,4" />

            <!-- Descrição -->
            <Label Text="Sobre o Aplicativo"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#333" />

            <Label TextColor="#555"
                   FontSize="14"
                   LineHeight="1.5">
                <Label.Text>
O App Hotel é um aplicativo de reservas desenvolvido como projeto prático da disciplina Programação Mobile I, do curso Técnico em Desenvolvimento de Sistemas da ETEC.

O projeto explora os principais componentes de interface gráfica do .NET MAUI, como Entry, DatePicker, Picker, Stepper e navegação entre páginas com BindingContext.
                </Label.Text>
            </Label>

            <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,4,0,4" />

            <!-- Informações do desenvolvedor -->
            <Label Text="Desenvolvedor"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#333" />

            <!-- Card do desenvolvedor -->
            <Border Stroke="#E0E0E0"
                    StrokeThickness="1"
                    BackgroundColor="#F8F9FA"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="👤  Aluno ETEC"
                           FontSize="14"
                           TextColor="#333" />
                    <Label Text="🎓  Técnico em Desenvolvimento de Sistemas"
                           FontSize="14"
                           TextColor="#333" />
                    <Label Text="🏫  Centro Paula Souza — ETEC"
                           FontSize="14"
                           TextColor="#333" />
                    <Label Text="📅  Ano: 2024"
                           FontSize="14"
                           TextColor="#333" />
                    <Label Text="📘  Disciplina: Programação Mobile I"
                           FontSize="14"
                           TextColor="#333" />
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,4,0,4" />

            <!-- Tecnologias usadas -->
            <Label Text="Tecnologias Utilizadas"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#333" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                <Border Grid.Row="0" Grid.Column="0" Stroke="#BBDEFB" BackgroundColor="#E3F2FD" Padding="12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label Text=".NET MAUI" FontAttributes="Bold" TextColor="#1A73E8" FontSize="13"/>
                        <Label Text="Framework" TextColor="#555" FontSize="11"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Stroke="#C8E6C9" BackgroundColor="#E8F5E9" Padding="12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label Text="C# 12" FontAttributes="Bold" TextColor="#2E7D32" FontSize="13"/>
                        <Label Text="Linguagem" TextColor="#555" FontSize="11"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Stroke="#F8BBD0" BackgroundColor="#FCE4EC" Padding="12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label Text="XAML" FontAttributes="Bold" TextColor="#C62828" FontSize="13"/>
                        <Label Text="Interface" TextColor="#555" FontSize="11"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Stroke="#E1BEE7" BackgroundColor="#F3E5F5" Padding="12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label Text=".NET 8.0" FontAttributes="Bold" TextColor="#6A1B9A" FontSize="13"/>
                        <Label Text="Plataforma" TextColor="#555" FontSize="11"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Botão voltar -->
            <Button Text="Voltar"
                    Clicked="Button_Voltar_Clicked"
                    BackgroundColor="Transparent"
                    TextColor="#1A73E8"
                    BorderColor="#1A73E8"
                    BorderWidth="1"
                    CornerRadius="8"
                    Margin="0,10,0,20" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
